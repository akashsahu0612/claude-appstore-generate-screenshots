# Snapfile — Auto-generated by claude-appstore-generate-screenshots
# Place this file at: fastlane/Snapfile (or project root)
# Run with: bundle exec fastlane snapshot

# ─── Devices ─────────────────────────────────────────────────────────────────
# Target device(s) for screenshot capture
devices([
  "iPhone 17 Pro"
  # Add more device sizes if needed:
  # "iPhone 15 Plus",
  # "iPad Pro (12.9-inch) (6th generation)",
])

# ─── Languages ───────────────────────────────────────────────────────────────
languages([
  "en-US"
])

# ─── Scheme ──────────────────────────────────────────────────────────────────
# The UITest scheme that contains AsoSnapshotTests
scheme("{{APP_TARGET}}UITests")

# ─── Output ──────────────────────────────────────────────────────────────────
# Where to save screenshots (relative to project root)
output_directory("./aso-screenshots")

# Clear existing screenshots before each run
clear_previous_screenshots(true)

# ─── App Launch Arguments ────────────────────────────────────────────────────
# Pass credentials as launch environment variables (not arguments)
# These are read via ProcessInfo.processInfo.environment in the test
launch_environment({
  "TEST_EMAIL" => ENV["TEST_EMAIL"] || "",
  "TEST_PASSWORD" => ENV["TEST_PASSWORD"] || ""
})

# ─── Build Options ───────────────────────────────────────────────────────────
# Skip building if already built (speeds up re-runs)
reinstall_app(false)

# Erase simulator before running to ensure clean state
erase_simulator(false)

# Override status bar for clean screenshots
override_status_bar(true)
override_status_bar_arguments("--time 9:41 --dataNetwork wifi --wifiMode active --wifiBars 3 --cellularMode notSupported --batteryState charged --batteryLevel 100")

